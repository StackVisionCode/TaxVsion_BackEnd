{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build Tenant API",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/src/Services/Tenant/TaxVision.Tenant.Api/TaxVision.Tenant.Api.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/TaxVision.slnx",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch Tenant API",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "--project",
                "${workspaceFolder}/src/Services/Tenant/TaxVision.Tenant.Api/TaxVision.Tenant.Api.csproj",
                "run",
                "--launch-profile",
                "http"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
