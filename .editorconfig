root = true

[*]
end_of_line = crlf
charset = utf-8
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_size = 4
csharp_style_expression_bodied_methods = true
csharp_new_line_before_open_brace = all

[*.{json,yml,yaml,xml,csproj,slnx,props,targets}]
indent_size = 2
