{
  "title": "PaymentApp — Overview",
  "uid": "taxvision-payment-app",
  "tags": ["taxvision", "payments"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Renewals attempted/succeeded/failed por hora",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(paymentapp_saas_payments_attempted_total[1h])) by (type)", "legendFormat": "attempted — {{type}}", "refId": "A" },
        { "expr": "sum(rate(paymentapp_saas_payments_succeeded_total[1h])) by (type)", "legendFormat": "succeeded — {{type}}", "refId": "B" },
        { "expr": "sum(rate(paymentapp_saas_payments_failed_total[1h])) by (type)", "legendFormat": "failed — {{type}}", "refId": "C" }
      ]
    },
    {
      "id": 2,
      "title": "Dunning queue depth (pagos Failed con retry vencido)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "paymentapp_dunning_queue_depth", "refId": "A" }]
    },
    {
      "id": 3,
      "title": "MRR (proxy — renovaciones de suscripción exitosas, 30d)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "targets": [{ "expr": "paymentapp_mrr_usd", "refId": "A" }]
    },
    {
      "id": 4,
      "title": "Latencia del provider (p95, ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(paymentapp_provider_latency_ms_bucket[5m])) by (le, provider, method))",
          "legendFormat": "{{provider}} — {{method}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Refunds y chargebacks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(paymentapp_saas_payments_refunded_total[1h])) by (provider)", "legendFormat": "refunded — {{provider}}", "refId": "A" },
        { "expr": "sum(rate(paymentapp_saas_payments_chargeback_total[1h])) by (provider)", "legendFormat": "chargeback — {{provider}}", "refId": "B" }
      ]
    },
    {
      "id": 6,
      "title": "Failures por código (top 10)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, sum(increase(paymentapp_saas_payments_failed_total[24h])) by (failure_code))",
          "legendFormat": "{{failure_code}}",
          "refId": "A"
        }
      ]
    }
  ]
}
