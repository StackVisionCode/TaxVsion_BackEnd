{
  "title": "TaxVision — Microservicio (detalle)",
  "uid": "taxvision-service-detail",
  "tags": ["taxvision"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Servicio",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(http_server_request_duration_seconds_count, job)", "refId": "job" },
        "refresh": 2,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request rate por ruta (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"$job\"}[5m])) by (http_route)",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latencia p50/p95/p99 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{job=\"$job\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{job=\"$job\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{job=\"$job\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "Errores 5xx por ruta (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"$job\", http_response_status_code=~\"5..\"}[5m])) by (http_route)",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Llamadas salientes HttpClient — latencia p95 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_client_request_duration_seconds_bucket{job=\"$job\"}[5m])) by (le, server_address))",
          "legendFormat": "{{server_address}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": ".NET GC heap size (bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "expr": "process_runtime_dotnet_gc_heap_size_bytes{job=\"$job\"}",
          "legendFormat": "{{generation}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": ".NET GC colecciones/s",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(process_runtime_dotnet_gc_collections_count_total{job=\"$job\"}[5m])",
          "legendFormat": "gen {{generation}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Thread pool — hilos activos",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_runtime_dotnet_thread_pool_threads_count{job=\"$job\"}",
          "legendFormat": "threads",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Logs del servicio",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"$job\"}",
          "refId": "A"
        }
      ]
    }
  ]
}
