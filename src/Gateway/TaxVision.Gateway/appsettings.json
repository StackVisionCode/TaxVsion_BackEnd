{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "TaxVision.Auth",
    "Audience": "TaxVision.Services"
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/{**catch-all}" }
      },
      "tenant": {
        "ClusterId": "tenant",
        "Match": { "Path": "/tenants/{**catch-all}" }
      },
      "customer": {
        "ClusterId": "customer",
        "Match": { "Path": "/customers/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth": {
        "Destinations": {
          "auth1": { "Address": "http://localhost:5124/" }
        }
      },
      "tenant": {
        "Destinations": {
          "tenant1": { "Address": "http://localhost:5217/" }
        }
      },
      "customer": {
        "Destinations": {
          "customer1": { "Address": "http://localhost:5263" }
        }
      }
    }
  }
}
