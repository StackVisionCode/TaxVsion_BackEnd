{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "TaxVision.Auth",
    "Audience": "TaxVision.Services"
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/{**catch-all}" }
      },
      "tenant": {
        "ClusterId": "tenant",
        "Match": { "Path": "/tenants/{**catch-all}" }
      },
      "enrollments": {
        "ClusterId": "subscription",
        "Match": { "Path": "/enrollments/{**catch-all}" },
        "AuthorizationPolicy": "anonymous"
      },
      "subscriptions": {
        "ClusterId": "subscription",
        "Match": { "Path": "/subscriptions/{**catch-all}" }
      },
      "plans": {
        "ClusterId": "subscription",
        "Match": { "Path": "/api/plans/{**catch-all}" }
      },
      "modules": {
        "ClusterId": "subscription",
        "Match": { "Path": "/api/modules/{**catch-all}" }
      },
      "subscription-modules": {
        "ClusterId": "subscription",
        "Match": { "Path": "/api/subscription-modules/{**catch-all}" }
      },
      "payments": {
        "ClusterId": "payment",
        "Match": { "Path": "/payments/{**catch-all}" }
      },
      "webhooks": {
        "ClusterId": "payment",
        "Match": { "Path": "/webhooks/{**catch-all}" },
        "AuthorizationPolicy": "anonymous"
      }
    },
    "Clusters": {
      "auth": {
        "Destinations": {
          "auth1": { "Address": "http://localhost:5124/" }
        }
      },
      "tenant": {
        "Destinations": {
          "tenant1": { "Address": "http://localhost:5217/" }
        }
      },
      "subscription": {
        "Destinations": {
          "subscription1": { "Address": "http://localhost:5176/" }
        }
      },
      "payment": {
        "Destinations": {
          "payment1": { "Address": "http://localhost:5008/" }
        }
      }
    }
  }
}
