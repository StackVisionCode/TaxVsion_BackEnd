{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "TaxVision.Auth",
    "Audience": "TaxVision.Services"
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/{**catch-all}" }
      },
      "tenant": {
        "ClusterId": "tenant",
        "Match": { "Path": "/tenants/{**catch-all}" }
      },
      "enrollments": {
        "ClusterId": "subscription",
        "Match": { "Path": "/enrollments/{**catch-all}" },
        "AuthorizationPolicy": "anonymous"
      },
      "subscriptions": {
        "ClusterId": "subscription",
        "Match": { "Path": "/subscriptions/{**catch-all}" }
      },
      "plans": {
        "ClusterId": "subscription",
        "Match": { "Path": "/api/plans/{**catch-all}" },
        "AuthorizationPolicy": "anonymous"
      },
      "modules": {
        "ClusterId": "subscription",
        "Match": { "Path": "/api/modules/{**catch-all}" },
        "AuthorizationPolicy": "anonymous"
      },
