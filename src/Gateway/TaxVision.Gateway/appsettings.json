{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "TaxVision.Auth",
    "Audience": "TaxVision.Services"
  },
  "Cors": {
    "Origins": ["http://localhost:5173", "http://localhost:4200"]
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/{**catch-all}" },
        "Transforms": [{ "RequestHeaderOriginalHost": "true" }]
      },
      "tenant": {
        "ClusterId": "tenant",
        "Match": { "Path": "/tenants/{**catch-all}" }
      },
      "customer": {
        "ClusterId": "customer",
        "Match": { "Path": "/customers/{**catch-all}" }
      },
      "plans": {
        "ClusterId": "subscription",
        "Match": { "Path": "/plans/{**catch-all}" }
      },
      "subscriptions": {
        "ClusterId": "subscription",
        "Match": { "Path": "/subscriptions/{**catch-all}" }
      },
      "seats": {
        "ClusterId": "subscription",
        "Match": { "Path": "/seats/{**catch-all}" }
      },
      "addons": {
        "ClusterId": "subscription",
        "Match": { "Path": "/addons/{**catch-all}" }
      },
      "entitlements": {
        "ClusterId": "subscription",
        "Match": { "Path": "/entitlements/{**catch-all}" }
      },
      "audit": {
        "ClusterId": "subscription",
        "Match": { "Path": "/audit/{**catch-all}" }
      },
      "admin-subscription": {
        "ClusterId": "subscription",
        "Match": { "Path": "/admin/subscription/{**catch-all}" }
      },
      "notifications": {
        "ClusterId": "notification",
        "Match": { "Path": "/notifications/{**catch-all}" }
      },
      "postmaster": {
        "ClusterId": "postmaster",
        "Match": { "Path": "/postmaster/{**catch-all}" }
      },
      "scribe": {
        "ClusterId": "scribe",
        "Match": { "Path": "/scribe/{**catch-all}" }
      },
      "connectors": {
        "ClusterId": "connectors",
        "Match": { "Path": "/connectors/{**catch-all}" }
      },
      "correspondence": {
        "ClusterId": "correspondence",
        "Match": { "Path": "/correspondence/{**catch-all}" }
      },
      "cloudstorage": {
        "ClusterId": "cloudstorage",
        "Match": { "Path": "/storage/{**catch-all}" }
      },
      "signature": {
        "ClusterId": "signature",
        "Match": { "Path": "/signature/{**catch-all}" }
      },
      "communication": {
        "ClusterId": "communication",
        "Match": { "Path": "/communication/{**catch-all}" }
      },
      "communication-socket": {
        "ClusterId": "communication",
        "Match": { "Path": "/communication/socket.io/{**catch-all}" }
      },
      "payments-app": {
        "ClusterId": "paymentapp",
        "Match": { "Path": "/payments-app/{**catch-all}" }
      },
      "payments-client": {
        "ClusterId": "paymentclient",
        "Match": { "Path": "/payments-client/{**catch-all}" }
      },
      "growth": {
        "ClusterId": "growth",
        "Match": { "Path": "/growth/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth": {
        "Destinations": {
          "auth1": { "Address": "http://localhost:5124/" }
        }
      },
      "tenant": {
        "Destinations": {
          "tenant1": { "Address": "http://localhost:5217/" }
        }
      },
      "customer": {
        "Destinations": {
          "customer1": { "Address": "http://localhost:5263" }
        }
      },
      "subscription": {
        "Destinations": {
          "subscription1": { "Address": "http://localhost:5360/" }
        }
      },
      "notification": {
        "Destinations": {
          "notification1": { "Address": "http://localhost:5320/" }
        }
      },
      "postmaster": {
        "Destinations": {
          "postmaster1": { "Address": "http://localhost:5370/" }
        }
      },
      "scribe": {
        "Destinations": {
          "scribe1": { "Address": "http://localhost:5380/" }
        }
      },
      "connectors": {
        "Destinations": {
          "connectors1": { "Address": "http://localhost:5390/" }
        }
      },
      "correspondence": {
        "Destinations": {
          "correspondence1": { "Address": "http://localhost:5400/" }
        }
      },
      "cloudstorage": {
        "Destinations": {
          "cloudstorage1": { "Address": "http://localhost:5330/" }
        },
        "HttpRequest": {
          "ActivityTimeout": "00:10:00"
        }
      },
      "signature": {
        "Destinations": {
          "signature1": { "Address": "http://localhost:5340/" }
        }
      },
      "communication": {
        "Destinations": {
          "communication1": { "Address": "http://localhost:5350/" }
        },
        "HttpRequest": {
          "ActivityTimeout": "01:00:00"
        }
      },
      "paymentapp": {
        "Destinations": {
          "paymentapp1": { "Address": "http://localhost:5430/" }
        }
      },
      "paymentclient": {
        "Destinations": {
          "paymentclient1": { "Address": "http://localhost:5420/" }
        }
      },
      "growth": {
        "Destinations": {
          "growth1": { "Address": "http://localhost:5410/" }
        }
      }
    }
  }
}
