# ---------- HTTP + Socket.IO ----------
COMMUNICATION_HTTP_HOST=0.0.0.0
COMMUNICATION_HTTP_PORT=5350
NODE_ENV=development
LOG_LEVEL=info
SERVICE_NAME=communication-service

# ---------- SQL Server (via Prisma) ----------
# DB propia por servicio, análoga a TaxVision_Signature/TaxVision_Notification.
COMMUNICATION_DB_CONNECTION="sqlserver://host.docker.internal:1433;database=TaxVision_Communication;user=sa;password=REPLACE;encrypt=false;trustServerCertificate=true"

# ---------- Redis (adapter Socket.IO + presence + rate limit + denylist) ----------
COMMUNICATION_REDIS_URI=redis://redis:6379/0
# Prefijo compartido con Auth para leer el denylist de sesiones revocadas.
COMMUNICATION_SESSION_DENYLIST_PREFIX=auth:session-denylist

# ---------- RabbitMQ ----------
COMMUNICATION_RABBITMQ_URI=amqp://taxvision:REPLACE@rabbitmq:5672
COMMUNICATION_RABBITMQ_EXCHANGE=taxvision-events
COMMUNICATION_RABBITMQ_QUEUE=communication-events
COMMUNICATION_RABBITMQ_DLQ=communication-events.dlq

# ---------- JWT (verificación via JWKS remoto de Auth — RS256) ----------
# Comunicación entre servicios: verifica el token con la JWK pública del Auth.
COMMUNICATION_JWT_ISSUER=TaxVision.Auth
COMMUNICATION_JWT_AUDIENCE=TaxVision.Services
COMMUNICATION_JWKS_URI=http://auth-api:8080/auth/.well-known/jwks.json
# Cache JWKS en segundos (Auth rota la clave rara vez; 5 min está bien).
COMMUNICATION_JWKS_CACHE_MAX_AGE_SECONDS=300


# ---------- TURN (Coturn) — Fase 2/3 ----------
COMMUNICATION_TURN_URL=turn:turn:3478
COMMUNICATION_TURN_STATIC_AUTH_SECRET=REPLACE
COMMUNICATION_TURN_TTL_SECONDS=300

# ---------- OpenTelemetry ----------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=communication-service

# ---------- CORS ----------
# Lista separada por comas.
COMMUNICATION_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ---------- Rate limit por Socket (Fase Backend 11 — antes literales inline) ----------
COMMUNICATION_RATE_LIMIT_CALL_INITIATE_MAX=10
COMMUNICATION_RATE_LIMIT_CALL_INITIATE_WINDOW_SECONDS=30
COMMUNICATION_RATE_LIMIT_CALL_SIGNAL_MAX=60
COMMUNICATION_RATE_LIMIT_CALL_SIGNAL_WINDOW_SECONDS=10
COMMUNICATION_RATE_LIMIT_MEETING_CHAT_SEND_MAX=30
COMMUNICATION_RATE_LIMIT_MEETING_CHAT_SEND_WINDOW_SECONDS=10
COMMUNICATION_RATE_LIMIT_CHAT_SEND_MAX=30
COMMUNICATION_RATE_LIMIT_CHAT_SEND_WINDOW_SECONDS=10
COMMUNICATION_RATE_LIMIT_CHAT_EDIT_MAX=20
COMMUNICATION_RATE_LIMIT_CHAT_EDIT_WINDOW_SECONDS=10
COMMUNICATION_RATE_LIMIT_CHAT_TYPING_MAX=20
COMMUNICATION_RATE_LIMIT_CHAT_TYPING_WINDOW_SECONDS=10

# ---------- M2M contra Auth + CloudStorage (Fase Backend 8) ----------
# Sync HTTP a CloudStorage para validar metadata de grabaciones al attach
# (bug #245). Reusa el mismo client-id/secret que ya existia en .env para el
# TranscriptWorker.
COMMUNICATION_SERVICE_AUTH_CLIENT_ID=communication-worker
COMMUNICATION_SERVICE_AUTH_CLIENT_SECRET=REPLACE
COMMUNICATION_AUTH_BASE_URL=http://auth-api:8080
COMMUNICATION_CLOUDSTORAGE_BASE_URL=http://cloudstorage-api:8080

# ---------- Meeting invitations (Fase Backend 5) ----------
# Base del frontend para construir joinUrl = {base}/join?token=xxx.
COMMUNICATION_FRONTEND_BASE_URL=http://localhost:5173
# Secreto local HS256 para firmar/verificar el shortLivedJoinTicket del guest
# (nunca sale de este proceso — no confundir con el JWKS de Auth, que es para
# usuarios con cuenta). Generar con: openssl rand -hex 32
COMMUNICATION_JOIN_TICKET_SECRET=REPLACE_WITH_64_HEX_CHARS
COMMUNICATION_JOIN_TICKET_TTL_SECONDS=300
