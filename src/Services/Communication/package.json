{
  "name": "@taxvision/communication",
  "version": "0.1.0",
  "private": true,
  "description": "TaxVision Communication microservice — chat, calls, meetings, realtime notifs (Node.js + TypeScript + Socket.IO + Prisma + DDD).",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "dev": "tsx watch --clear-screen=false src/main.ts",
    "start": "node --enable-source-maps dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,json}\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "10.0.1",
    "@fastify/helmet": "12.0.1",
    "@fastify/rate-limit": "10.1.1",
    "@fastify/sensible": "6.0.2",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/auto-instrumentations-node": "0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.220.0",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-node": "0.220.0",
    "@opentelemetry/semantic-conventions": "1.27.0",
    "@prisma/client": "5.22.0",
    "@socket.io/redis-adapter": "8.3.0",
    "amqplib": "0.10.4",
    "argon2": "0.41.1",
    "dotenv": "16.4.5",
    "fastify": "5.10.0",
    "fastify-type-provider-zod": "4.0.2",
    "ioredis": "5.4.1",
    "jose": "5.9.6",
    "mediasoup": "^3.21.0",
    "nanoid": "5.0.9",
    "pino": "9.5.0",
    "pino-http": "10.3.0",
    "prom-client": "15.1.3",
    "socket.io": "4.8.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/amqplib": "0.10.6",
    "@types/node": "20.17.9",
    "@typescript-eslint/eslint-plugin": "8.17.0",
    "@typescript-eslint/parser": "8.17.0",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.5",
    "eslint-config-prettier": "9.1.0",
    "prettier": "3.4.2",
    "prisma": "5.22.0",
    "rimraf": "6.0.1",
    "tsx": "4.23.0",
    "typescript": "5.6.3",
    "vitest": "4.1.10"
  }
}
