{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "TaxVision.Auth",
    "Audience": "TaxVision.Services",
    "ValidAudiences": [
      "TaxVision.Services",
      "taxvision-growth"
    ]
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Growth": {
    "Codes": {
      "TokenHashing": {
        "Pepper": ""
      }
    },
    "Referrals": {
      "TokenHashing": {
        "Pepper": ""
      }
    },
    "BusinessIdempotency": {
      "RetentionDays": 2557
    },
    "PaymentOutcomeVerifier": {
      "Enabled": false
    }
  },
  "ConnectionStrings": {
    "Default": ""
  },
  "AllowedHosts": "*"
}
