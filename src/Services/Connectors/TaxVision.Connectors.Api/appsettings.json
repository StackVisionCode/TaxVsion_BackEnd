{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "TaxVision.Auth",
    "Audience": "TaxVision.Services"
  },
  "Authorization": {
    "PermissionsSource": "Projection"
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Encryption": {
    "MasterKey": ""
  },
  "Portal": {
    "BaseUrl": "http://localhost:4200"
  },
  "Connectors": {
    "OAuth": {
      "Google": {
        "ClientId": "",
        "ClientSecret": ""
      },
      "Microsoft": {
        "ClientId": "",
        "ClientSecret": ""
      }
    },
    "Watch": {
      "Gmail": {
        "TopicName": ""
      },
      "Graph": {
        "NotificationUrl": "",
        "ClientState": ""
      }
    },
    "Webhooks": {
      "GmailPush": {
        "ExpectedAudience": ""
      }
    },
    "SendRateLimit": {
      "MaxRequestsPerMinute": 20
    },
    "Reconciliation": {
      "IntervalMinutes": 15
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "",
    "Redis": ""
  }
