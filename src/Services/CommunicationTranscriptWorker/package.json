{
  "name": "@taxvision/communication-transcript-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Worker separado: transcribe grabaciones de Communication (calls/meetings) con whisper.cpp — proceso independiente para no competir por CPU con el realtime de Communication.",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "dev": "tsx watch --clear-screen=false src/main.ts",
    "start": "node --enable-source-maps dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run"
  },
  "dependencies": {
    "amqplib": "0.10.4",
    "dotenv": "16.4.5",
    "ioredis": "5.4.1",
    "minio": "8.0.7",
    "pino": "9.5.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/amqplib": "0.10.6",
    "@types/node": "20.17.9",
    "@typescript-eslint/eslint-plugin": "8.17.0",
    "@typescript-eslint/parser": "8.17.0",
    "eslint": "9.39.5",
    "eslint-config-prettier": "9.1.0",
    "rimraf": "6.0.1",
    "tsx": "4.23.0",
    "typescript": "5.6.3",
    "vitest": "4.1.10"
  }
}
