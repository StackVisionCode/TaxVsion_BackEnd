{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "TaxVision.Auth",
    "Audience": "TaxVision.Services",
    "AccessMinutes": 15
  },
  "RefreshToken": {
    "ExpirationDays": 30
  },
  "PlatformBootstrap": {
    "Enabled": false,
    "InvitationValidityHours": 24
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "AllowedHosts": "*"
}
