{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "TaxVision.Auth",
    "Audience": "TaxVision.Services",
    "AccessMinutes": 15,
    "PrivateKeyPath": ""
  },
  "RefreshToken": {
    "ExpirationDays": 14
  },
  "Invitations": {
    "ReturnRawToken": false,
    "ValidityDays": 7
  },
  "Mfa": {
    "EncryptionKey": ""
  },
  "PlatformBootstrap": {
    "Enabled": false,
    "InvitationValidityHours": 24
  },
  "PlatformEmergencyAccess": {
    "Enabled": false
  },
  "ServiceAuth": {
    "TokenLifetimeMinutes": 10,
    "Clients": []
  },
  "TenantDomains": {
    "BaseDomain": "taxprocore.com",
    "EnforceHostResolution": true
  },
  "ReverseProxyTrust": {
    "KnownProxies": [],
    "KnownNetworks": [],
    "RealIpHeaderName": "X-Forwarded-For"
  },
  "Cloudflare": {
    "BaseUrl": "https://api.cloudflare.com/client/v4/",
    "ApiToken": "",
    "ZoneId": ""
  },
  "Terms": {
    "CurrentVersion": "2026-07-14"
  },
  "Authorization": {
    "PermissionsSource": "Projection"
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "AllowedHosts": "*"
}
