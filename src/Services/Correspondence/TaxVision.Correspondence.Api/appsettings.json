{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "TaxVision.Auth",
    "Audience": "TaxVision.Services"
  },
  "Authorization": {
    "ResourceOwnership": {
      "Enabled": false
    },
    "PermissionsSource": "Projection"
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": ""
  },
  "Correspondence": {
    "ServiceAuth": {
      "AuthBaseUrl": "http://localhost:5124",
      "ClientId": "",
      "ClientSecret": ""
    },
    "Customer": {
      "BaseUrl": "http://localhost:5263"
    },
    "Connectors": {
      "BaseUrl": "http://localhost:5390"
    },
    "Postmaster": {
      "BaseUrl": "http://localhost:5370"
    },
    "Ingest": {
      "EnableUnmatchedDebug": false,
      "EnableSubjectThreadingFallback": false
    },
    "CloudStorage": {
      "BaseUrl": "http://localhost:5210"
    },
    "Minio": {
      "Endpoint": "localhost:9000",
      "AccessKey": "",
      "SecretKey": "",
      "UseTls": false,
      "TempBucket": "taxvision-temp",
      "SourcePrefix": "correspondence"
    },
    "DraftCleanup": {
      "Enabled": false,
      "AbandonedAfterDays": 30,
      "BatchSize": 200
    },
    "Reconciliation": {
      "Enabled": true
    }
  }
}
