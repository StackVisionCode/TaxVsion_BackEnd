{
	"info": {
		"_postman_id": "5655905e-59ee-49c4-8c18-ab7b22b5307a",
		"name": "TaxVision - Subscription",
		"description": "Colección de pruebas del microservicio Subscription de TaxVision. Usa el environment TaxVisionBackEnd (variable UrlBase apuntando al Gateway, p. ej. http://localhost:5047).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "GetPlans",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{UrlBase}}/plans",
					"host": [
						"{{UrlBase}}"
					],
					"path": [
						"plans"
					]
				},
				"description": "Catalogo publico de planes para la landing."
			},
			"response": [],
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const plans = pm.response.json();\r",
							"if (Array.isArray(plans) && plans.length > 0) {\r",
							"    pm.environment.set('firstPlanCode', plans[0].code);\r",
							"    pm.environment.set('secondPlanCode', plans[1]?.code || plans[0].code);\r",
							"    console.log('Plans loaded:', plans.map(p => p.code).join(', '));\r",
							"}\r"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			]
		},
		{
			"name": "GetMySubscription",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{accessToken}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{UrlBase}}/subscriptions/me",
					"host": [
						"{{UrlBase}}"
					],
					"path": [
						"subscriptions",
						"me"
					]
				},
				"description": "Suscripcion del tenant: plan, limites, renovacion, estado."
			},
			"response": [],
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const s = pm.response.json();\r",
							"if (s && s.id) {\r",
							"    pm.environment.set('subscriptionId', s.id);\r",
							"    pm.environment.set('currentPlanCode', s.planCode);\r",
							"    pm.environment.set('currentSeats', s.seats);\r",
							"    pm.environment.set('subscriptionStatus', s.status);\r",
							"    console.log('Subscription:', s.id, s.planCode, s.status);\r",
							"}\r"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			]
		},
		{
			"name": "ChangePlan",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{accessToken}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{UrlBase}}/subscriptions/change-plan",
					"host": [
						"{{UrlBase}}"
					],
					"path": [
						"subscriptions",
						"change-plan"
					]
				},
				"body": {
					"mode": "raw",
					"raw": "{\n  \"planCode\": \"pro\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"description": "Upgrade/downgrade de plan (TenantAdmin)."
			},
			"response": []
		},
		{
			"name": "PurchaseSeats",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{accessToken}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{UrlBase}}/subscriptions/seats",
					"host": [
						"{{UrlBase}}"
					],
					"path": [
						"subscriptions",
						"seats"
					]
				},
				"body": {
					"mode": "raw",
					"raw": "{\n  \"additionalSeats\": 5\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				}
			},
			"response": []
		},
		{
			"name": "CancelSubscription",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{accessToken}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{UrlBase}}/subscriptions/cancel",
					"host": [
						"{{UrlBase}}"
					],
					"path": [
						"subscriptions",
						"cancel"
					]
				}
			},
			"response": []
		},
		{
			"name": "SuspendSubscription",
			"request": {
				"method": "PATCH",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{accessToken}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{UrlBase}}/subscriptions/{{tenantId}}/suspend",
					"host": [
						"{{UrlBase}}"
					],
					"path": [
						"subscriptions",
						"{{tenantId}}",
						"suspend"
					]
				},
				"body": {
					"mode": "raw",
					"raw": "{\n  \"reason\": \"payment_failed\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"description": "Solo PlatformAdmin."
			},
			"response": []
		},
		{
			"name": "ReactivateSubscription",
			"request": {
				"method": "PATCH",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{accessToken}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{UrlBase}}/subscriptions/{{tenantId}}/reactivate",
					"host": [
						"{{UrlBase}}"
					],
					"path": [
						"subscriptions",
						"{{tenantId}}",
						"reactivate"
					]
				},
				"description": "Solo PlatformAdmin."
			},
			"response": []
		}
	]
}
