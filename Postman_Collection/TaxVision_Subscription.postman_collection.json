								"{{UrlBase}}"
							],
							"path": [
								"subscriptions",
								"change-plan"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"planCode\": \"pro\",\n  \"billingCycle\": \"Yearly\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"description": "Upgrade/downgrade de plan (permiso: subscription.plan.change). Si SubscriptionTenantSettings.PlanChangeEffective es Immediate (default), cambia y factura de una vez; si es EndOfPeriod, encola un PlanChangeRequest para GetPendingPlanChange. billingCycle es opcional (\"Monthly\"/\"Yearly\") — se manda junto con el plan en el mismo request para elegir/cambiar el ciclo de facturacion a la vez que el plan. Si se omite o es null, mantiene el ciclo actual. Sin prorrateo: el periodo en curso sigue como esta (ya cobrado con el ciclo/precio anteriores); el ciclo nuevo se cobra recien en la proxima renovacion, al precio de ESE ciclo."
					},
					"response": []
				},
