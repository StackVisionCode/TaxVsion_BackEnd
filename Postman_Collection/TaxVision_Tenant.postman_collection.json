{
	"info": {
		"_postman_id": "682cb299-6c0d-46d2-ba49-764f6fb609c3",
		"name": "TaxVision - Tenant",
		"description": "Colección de pruebas del microservicio Tenant de TaxVision. Usa el environment TaxVisionBackEnd (variable UrlBase apuntando al Gateway, p. ej. http://localhost:5047).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Registro_Tenant",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"\r",
							"const response = pm.response.json();\r",
							"\r",
							"pm.environment.set(\"tenantId\", response.id);\r",
							"pm.environment.set(\"invitationToken\", response.adminActivationToken);\r",
							""
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\r\n  \"name\": \"FreedomTax\",\r\n  \"subdomain\": \"freedomtax\",\r\n  \"adminEmail\": \"marcos@gmail.com\",\r\n  \"defaultTimeZoneId\": \"America/Santo_Domingo\"\r\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{UrlBase}}/tenants",
					"host": [
						"{{UrlBase}}"
					],
					"path": [
						"tenants"
					]
				}
			},
			"response": []
		},
		{
			"name": "ListTenants",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{accessToken}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{UrlBase}}/tenants?page=1&size=20",
					"host": [
						"{{UrlBase}}"
					],
					"path": [
						"tenants"
					],
					"query": [
						{
							"key": "page",
							"value": "1"
						},
						{
							"key": "size",
							"value": "20"
						}
					]
				},
				"description": "Lista paginada de tenants comerciales. Requiere rol PlatformAdmin."
			},
			"response": [],
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test(\"status 200\", () => pm.response.code === 200 || pm.expect.fail(\"Got \" + pm.response.code + \": \" + pm.response.text()));",
							"pm.test(\"respuesta es un arreglo\", () => pm.expect(pm.response.json()).to.be.an(\"array\"));"
						]
					}
				}
			]
		},
		{
			"name": "ChangeTenantStatus",
			"request": {
				"method": "PATCH",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{accessToken}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"status\": \"Suspended\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{UrlBase}}/tenants/{{tenantId}}/status",
					"host": [
						"{{UrlBase}}"
					],
					"path": [
						"tenants",
						"{{tenantId}}",
						"status"
					]
				},
				"description": "Cambia el estado del tenant (Active | Suspended | Closed). Requiere PlatformAdmin. Suspender/cerrar bloquea login y refresh."
			},
			"response": [],
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test(\"status 204\", () => pm.response.code === 204 || pm.expect.fail(\"Got \" + pm.response.code + \": \" + pm.response.text()));"
						]
					}
				}
			]
		}
	]
}
