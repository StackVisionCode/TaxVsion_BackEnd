            "url": { "raw": "{{base_url}}/communication/socket.io", "host": ["{{base_url}}"], "path": ["communication","socket.io"] }
          }
        },
        {
          "name": "[Doc] chat.message.delete — Eliminar mensaje",
          "request": {
            "method": "GET",
            "description": "C→S\n\nsocket.emit('chat.message.delete', {\n  conversationId: '{{conversation_id}}',\n  messageId: '{{message_id}}'\n})\n\nServidor emite 'chat.message.deleted' a todos.\nPublica integration event: communication.chat.message_deleted.v1",
            "url": { "raw": "{{base_url}}/communication/socket.io", "host": ["{{base_url}}"], "path": ["communication","socket.io"] }
          }
