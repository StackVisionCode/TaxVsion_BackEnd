		{
			"name": "Meetings",
			"item": [
				{
					"name": "CreateMeeting",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"status 201\", () => pm.response.code === 201 || pm.expect.fail(\"Got \" + pm.response.code + \": \" + pm.response.text()));",
									"const r = pm.response.json();",
									"if (r.meetingId) pm.environment.set('meetingId', r.meetingId);",
									"if (r.shortCode) pm.environment.set('meetingShortCode', r.shortCode);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
