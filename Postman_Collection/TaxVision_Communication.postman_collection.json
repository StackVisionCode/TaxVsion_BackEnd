		{
			"name": "WebRTC",
			"item": [
				{
					"name": "IssueIceCredentials",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"status 200\", () => pm.response.code === 200 || pm.expect.fail(\"Got \" + pm.response.code + \": \" + pm.response.text()));",
									"const r = pm.response.json();",
									"pm.test(\"tiene iceServers\", () => pm.expect(r).to.have.property('iceServers'));"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" }
						],
						"url": {
							"raw": "{{UrlBase}}/communication/webrtc/ice?ttl=300",
							"host": ["{{UrlBase}}"],
							"path": ["communication", "webrtc", "ice"],
							"query": [{ "key": "ttl", "value": "300" }]
						},
						"description": "Devuelve ICE servers + TURN efimero HMAC-SHA1. Sin secret configurado, retorna solo STUN publico."
					},
					"response": []
				}
			]
		},
