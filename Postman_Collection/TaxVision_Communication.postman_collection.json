{
  "info": {
    "name": "TaxVision — Communication Service",
    "description": "Colección completa del microservicio Communication.\nBase URL: {{base_url}} (ej. http://localhost:5350)\nAutenticación: Bearer {{token}} en cada request.\n\nSocket.IO se documenta como requests especiales de tipo 'socketio'.\nTodos los integration events son contratos RabbitMQ — no se prueban aquí directamente, pero sus payloads están documentados en los tests/scripts de cada carpeta.",
    "version": "2.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",       "value": "http://localhost:5350",        "type": "string" },
    { "key": "token",          "value": "<paste accessToken here>",     "type": "string" },
    { "key": "tenant_id",      "value": "<your tenantId UUID>",         "type": "string" },
    { "key": "user_id",        "value": "<your userId UUID>",           "type": "string" },
    { "key": "conversation_id","value": "",                             "type": "string" },
    { "key": "message_id",     "value": "",                             "type": "string" },
    { "key": "call_id",        "value": "",                             "type": "string" },
    { "key": "meeting_id",     "value": "",                             "type": "string" },
    { "key": "ticket_id",      "value": "",                             "type": "string" },
    { "key": "notification_id","value": "",                             "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "00 · Health",
      "item": [
        {
          "name": "Live",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/health/live", "host": ["{{base_url}}"], "path": ["health","live"] }
          }
        },
        {
          "name": "Ready",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/health/ready", "host": ["{{base_url}}"], "path": ["health","ready"] }
          }
        }
      ]
    },
    {
      "name": "01 · Chat — Conversaciones",
      "item": [
        {
          "name": "Crear conversación Direct",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('conversation_id', json.conversationId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"kind\": \"Direct\",\n  \"participantUserIds\": [\"{{user_id}}\", \"<otherUserId>\"]\n}"
            },
            "url": { "raw": "{{base_url}}/communication/conversations", "host": ["{{base_url}}"], "path": ["communication","conversations"] }
          }
        },
        {
          "name": "Crear conversación Group",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"kind\": \"Group\",\n  \"name\": \"Tax Season 2025 Team\",\n  \"participantUserIds\": [\"<userId1>\", \"<userId2>\", \"<userId3>\"]\n}"
            },
            "url": { "raw": "{{base_url}}/communication/conversations", "host": ["{{base_url}}"], "path": ["communication","conversations"] }
          }
        },
        {
          "name": "Listar mis conversaciones",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/communication/conversations?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["communication","conversations"],
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Detalle de conversación",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/communication/conversations/{{conversation_id}}", "host": ["{{base_url}}"], "path": ["communication","conversations","{{conversation_id}}"] }
          }
        },
        {
          "name": "Enviar mensaje (HTTP fallback)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('message_id', json.messageId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"body\": \"Hola equipo, ¿listos para la temporada fiscal?\",\n  \"kind\": \"Text\",\n  \"clientKey\": \"<nanoid-12-chars>\"\n}"
            },
            "url": { "raw": "{{base_url}}/communication/conversations/{{conversation_id}}/messages", "host": ["{{base_url}}"], "path": ["communication","conversations","{{conversation_id}}","messages"] }
          }
        },
        {
          "name": "Editar mensaje",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newBody\": \"Hola equipo, ¿listos para la temporada fiscal 2025?\"\n}"
            },
            "url": { "raw": "{{base_url}}/communication/conversations/{{conversation_id}}/messages/{{message_id}}", "host": ["{{base_url}}"], "path": ["communication","conversations","{{conversation_id}}","messages","{{message_id}}"] }
          }
        },
        {
          "name": "Eliminar mensaje",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/communication/conversations/{{conversation_id}}/messages/{{message_id}}", "host": ["{{base_url}}"], "path": ["communication","conversations","{{conversation_id}}","messages","{{message_id}}"] }
          }
        },
        {
          "name": "Añadir participante al grupo",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"<newMemberUserId>\"\n}"
            },
            "url": { "raw": "{{base_url}}/communication/conversations/{{conversation_id}}/participants", "host": ["{{base_url}}"], "path": ["communication","conversations","{{conversation_id}}","participants"] }
          }
        },
        {
          "name": "Remover participante",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/communication/conversations/{{conversation_id}}/participants/<userId>", "host": ["{{base_url}}"], "path": ["communication","conversations","{{conversation_id}}","participants","<userId>"] }
          }
        },
        {
          "name": "Marcar mensajes como leídos",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"untilMessageId\": \"{{message_id}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/communication/conversations/{{conversation_id}}/read", "host": ["{{base_url}}"], "path": ["communication","conversations","{{conversation_id}}","read"] }
          }
        }
      ]
    },
    {
      "name": "02 · Llamadas (WebRTC 1:1)",
      "description": "Las llamadas se inician/aceptan/rechazan por Socket.IO. Este endpoint solo obtiene los ICE servers para el cliente WebRTC.",
      "item": [
        {
          "name": "Obtener ICE servers (STUN/TURN)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/communication/webrtc/ice", "host": ["{{base_url}}"], "path": ["communication","webrtc","ice"] }
          },
          "response": [
            {
              "name": "200 — ICE servers con TTL",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"iceServers\": [\n    { \"urls\": [\"stun:stun.l.google.com:19302\"] },\n    { \"urls\": [\"turn:turn.example.com:3478\"], \"username\": \"taxvision\", \"credential\": \"<ephemeral>\" }\n  ],\n  \"ttlSeconds\": 86400\n}"
            }
          ]
        },
        {
          "name": "[Socket] Iniciar llamada — call.initiate",
          "request": {
            "method": "GET",
            "description": "Socket.IO C→S\n\nEmitir con:\nsocket.emit('call.initiate', { calleeUserId: '<uuid>', kind: 'Video' })\n\nEl servidor responde emitiendo 'call.incoming' al callee y un callId al caller.",
            "url": { "raw": "{{base_url}}/communication/socket.io", "host": ["{{base_url}}"], "path": ["communication","socket.io"] }
          }
        },
        {
          "name": "[Socket] Señalización WebRTC — call.signal",
          "request": {
            "method": "GET",
            "description": "Socket.IO C→S\n\nsocket.emit('call.signal', {\n  callId: '{{call_id}}',\n  signal: <RTCSessionDescriptionInit | RTCIceCandidateInit>\n})\n\nEl servidor reenvía la señal al otro participante. NUNCA se publica al bus RabbitMQ.",
            "url": { "raw": "{{base_url}}/communication/socket.io", "host": ["{{base_url}}"], "path": ["communication","socket.io"] }
          }
        }
      ]
    },
    {
      "name": "03 · Meetings",
      "item": [
        {
          "name": "Crear meeting",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('meeting_id', json.meetingId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Revisión documentos 1040\",\n  \"scheduledForUtc\": \"2026-07-15T18:00:00.000Z\",\n  \"passcode\": \"abc123\",\n  \"allowGuestLinks\": true\n}"
            },
            "url": { "raw": "{{base_url}}/communication/meetings", "host": ["{{base_url}}"], "path": ["communication","meetings"] }
          }
        },
        {
          "name": "Listar meetings del tenant",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/communication/meetings?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["communication","meetings"],
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Detalle de meeting",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/communication/meetings/{{meeting_id}}", "host": ["{{base_url}}"], "path": ["communication","meetings","{{meeting_id}}"] }
          }
        },
        {
          "name": "Actualizar meeting (título / schedule)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Revisión documentos 1040 — Actualizada\",\n  \"scheduledForUtc\": \"2026-07-16T19:00:00.000Z\"\n}"
            },
            "url": { "raw": "{{base_url}}/communication/meetings/{{meeting_id}}", "host": ["{{base_url}}"], "path": ["communication","meetings","{{meeting_id}}"] }
          }
        },
        {
          "name": "Cancelar meeting",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/communication/meetings/{{meeting_id}}", "host": ["{{base_url}}"], "path": ["communication","meetings","{{meeting_id}}"] }
          }
        },
        {
          "name": "Generar link de invitación",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inviteeEmail\": \"cliente@example.com\",\n  \"expiresInHours\": 48\n}"
            },
            "url": { "raw": "{{base_url}}/communication/meetings/{{meeting_id}}/invitations", "host": ["{{base_url}}"], "path": ["communication","meetings","{{meeting_id}}","invitations"] }
          }
        },
        {
          "name": "[Socket] Unirse al meeting — meeting.join",
          "request": {
            "method": "GET",
            "description": "Socket.IO C→S\n\nsocket.emit('meeting.join', { meetingId: '{{meeting_id}}', passcode: 'abc123' })\n\nSi el meeting está abierto → joinOrder asignado por servidor → emite 'meeting.participant.joined' a todos.\nSi el meeting tiene waiting room → va a waiting room y el host recibe 'meeting.participant.waiting'.",
            "url": { "raw": "{{base_url}}/communication/socket.io", "host": ["{{base_url}}"], "path": ["communication","socket.io"] }
          }
        },
        {
          "name": "[Socket] Señalización WebRTC en meeting — meeting.signal",
          "request": {
            "method": "GET",
            "description": "Socket.IO C→S (perfect negotiation)\n\nsocket.emit('meeting.signal', {\n  meetingId: '{{meeting_id}}',\n  toUserId: '<peerUserId>',\n  signal: <RTCSessionDescriptionInit | RTCIceCandidateInit>\n})\n\nPolite peer = mayor joinOrder. NUNCA se publica al bus.",
            "url": { "raw": "{{base_url}}/communication/socket.io", "host": ["{{base_url}}"], "path": ["communication","socket.io"] }
          }
        },
        {
          "name": "[Socket] Host — Admitir participante",
          "request": {
            "method": "GET",
            "description": "Socket.IO C→S (solo host)\n\nsocket.emit('meeting.host.admit', { meetingId: '{{meeting_id}}', userId: '<waitingUserId>' })",
            "url": { "raw": "{{base_url}}/communication/socket.io", "host": ["{{base_url}}"], "path": ["communication","socket.io"] }
          }
        },
        {
          "name": "[Socket] Host — Expulsar participante",
          "request": {
            "method": "GET",
            "description": "Socket.IO C→S (solo host)\n\nsocket.emit('meeting.host.remove', { meetingId: '{{meeting_id}}', userId: '<targetUserId>' })\n\nPublica integration event: communication.meeting.participant_removed_by_host.v1",
            "url": { "raw": "{{base_url}}/communication/socket.io", "host": ["{{base_url}}"], "path": ["communication","socket.io"] }
          }
        },
        {
          "name": "[Socket] Host — Transferir host",
          "request": {
            "method": "GET",
            "description": "Socket.IO C→S (solo host)\n\nsocket.emit('meeting.host.transfer', { meetingId: '{{meeting_id}}', newHostUserId: '<uuid>' })\n\nPublica integration event: communication.meeting.host_transferred.v1",
            "url": { "raw": "{{base_url}}/communication/socket.io", "host": ["{{base_url}}"], "path": ["communication","socket.io"] }
          }
        },
        {
          "name": "[Socket] Host — Iniciar grabación",
          "request": {
            "method": "GET",
            "description": "Socket.IO C→S (solo host)\n\nsocket.emit('meeting.host.recording_start', { meetingId: '{{meeting_id}}' })\n\nPublica integration event: communication.meeting.recording_started.v1",
            "url": { "raw": "{{base_url}}/communication/socket.io", "host": ["{{base_url}}"], "path": ["communication","socket.io"] }
          }
        }
      ]
    },
    {
      "name": "04 · Notificaciones",
      "item": [
        {
          "name": "Listar notificaciones (paginado)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/communication/notifications?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["communication","notifications"],
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Contador de no leídas",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/communication/notifications/unread-count", "host": ["{{base_url}}"], "path": ["communication","notifications","unread-count"] }
          },
          "response": [
            {
              "name": "200 — Unread count",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"unreadCount\": 5\n}"
            }
          ]
        },
        {
          "name": "Marcar notificación como leída",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/communication/notifications/{{notification_id}}/read", "host": ["{{base_url}}"], "path": ["communication","notifications","{{notification_id}}","read"] }
          }
        },
        {
          "name": "Marcar todas como leídas",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/communication/notifications/read-all", "host": ["{{base_url}}"], "path": ["communication","notifications","read-all"] }
          }
        }
      ]
    },
    {
      "name": "05 · Soporte Cross-Tenant",
      "description": "Canal Support: PlatformTenant (TaxVision) ↔ office tenant (preparadores).\nNUNCA preparador ↔ contribuyente.\nAgentes deben pertenecer al PlatformTenant y tener permiso support.agent.",
      "item": [
        {
          "name": "Abrir ticket",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('ticket_id', json.ticketId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Error al subir PDF de firma\",\n  \"initialMessage\": \"Cuando intento subir el formulario 1040, la carga falla con error 413.\",\n  \"category\": \"Technical\",\n  \"priority\": \"High\"\n}"
            },
            "url": { "raw": "{{base_url}}/communication/support", "host": ["{{base_url}}"], "path": ["communication","support"] }
          }
        },
        {
          "name": "Listar tickets (customer)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/communication/support?page=1&size=20",
              "host": ["{{base_url}}"],
              "path": ["communication","support"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Listar tickets (agente — mis asignados)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/communication/support?page=1&size=20&view=agent&mine=true",
              "host": ["{{base_url}}"],
              "path": ["communication","support"],
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "size",  "value": "20" },
                { "key": "view",  "value": "agent" },
                { "key": "mine",  "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Reclamar ticket (agente)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/communication/support/{{ticket_id}}/claim", "host": ["{{base_url}}"], "path": ["communication","support","{{ticket_id}}","claim"] }
          }
        },
        {
          "name": "Reasignar ticket",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newAgentUserId\": \"<UUID del nuevo agente>\"\n}"
            },
            "url": { "raw": "{{base_url}}/communication/support/{{ticket_id}}/reassign", "host": ["{{base_url}}"], "path": ["communication","support","{{ticket_id}}","reassign"] }
          }
        },
        {
          "name": "Escalar prioridad",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPriority\": \"Urgent\"\n}"
            },
            "url": { "raw": "{{base_url}}/communication/support/{{ticket_id}}/escalate", "host": ["{{base_url}}"], "path": ["communication","support","{{ticket_id}}","escalate"] }
          }
        },
        {
          "name": "Resolver ticket",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/communication/support/{{ticket_id}}/resolve", "host": ["{{base_url}}"], "path": ["communication","support","{{ticket_id}}","resolve"] }
          }
        },
        {
          "name": "Cerrar ticket",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/communication/support/{{ticket_id}}/close", "host": ["{{base_url}}"], "path": ["communication","support","{{ticket_id}}","close"] }
          }
        },
        {
          "name": "Reabrir ticket",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"El problema volvió a ocurrir después de marcar resuelto.\"\n}"
            },
            "url": { "raw": "{{base_url}}/communication/support/{{ticket_id}}/reopen", "host": ["{{base_url}}"], "path": ["communication","support","{{ticket_id}}","reopen"] }
          }
        }
      ]
    },
