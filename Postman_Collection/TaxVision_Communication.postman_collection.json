          "name": "[Doc] notification.received — Notificación push in-app",
          "request": {
            "method": "GET",
            "description": "S→C\n\nsocket.on('notification.received', (notification) => {\n  // notification.kind => routing a la UI\n  // Kinds disponibles:\n  // 'message_received' → abrir conversación\n  // 'call_missed' → historial de llamadas\n  // 'meeting_started' → unirse al meeting\n  // 'meeting_cancelled' → actualizar calendar\n  // 'meeting_rescheduled' → actualizar calendar\n  // 'support_ticket_new' → (agentes) abrir ticket\n  // 'support_ticket_claimed' → (customer) ver ticket\n  // 'support_ticket_escalated' → ver ticket\n  // 'support_ticket_resolved' → ver ticket\n  // 'support_ticket_reopened' → (agentes) ver ticket\n  // 'signature_signer_invited' → ir al portal firma\n  // 'signature_completed' → descargar documento firmado\n  // 'signature_expired' → renovar proceso de firma\n  // 'recording_ready' → descargar grabación\n})",
            "url": { "raw": "{{base_url}}/communication/socket.io", "host": ["{{base_url}}"], "path": ["communication","socket.io"] }
          }
        }
