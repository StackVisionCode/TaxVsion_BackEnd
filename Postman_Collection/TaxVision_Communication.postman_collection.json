          "name": "[Doc] chat.message.send — Enviar mensaje optimista",
          "request": {
            "method": "GET",
            "description": "C→S\n\nsocket.emit('chat.message.send', {\n  conversationId: '{{conversation_id}}',\n  body: 'Hola equipo',\n  kind: 'Text',\n  clientKey: nanoid(12)  // idempotencia — misma key = mismo mensaje\n})\n\nEl servidor responde emitiendo 'chat.message.new' a todos los participantes.\nPublica integration event: communication.chat.message_sent.v1",
            "url": { "raw": "{{base_url}}/communication/socket.io", "host": ["{{base_url}}"], "path": ["communication","socket.io"] }
          }
        },
