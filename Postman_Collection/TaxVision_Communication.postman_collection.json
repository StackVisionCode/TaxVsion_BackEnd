    },
    {
      "name": "07 · Analytics",
      "item": [
        {
          "name": "Snapshot diario (hoy)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/communication/analytics/snapshot", "host": ["{{base_url}}"], "path": ["communication","analytics","snapshot"] }
          },
          "response": [
            {
              "name": "200 — Daily snapshot",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"tenantId\": \"{{tenant_id}}\",\n  \"snapshotDateUtc\": \"2026-07-10\",\n  \"chat\": {\n    \"activeConversations\": 12,\n    \"messagesSent\": 148,\n    \"messagesEdited\": 3,\n    \"messagesDeleted\": 1,\n    \"attachmentsSent\": 7\n  },\n  \"calls\": {\n    \"totalCalls\": 5,\n    \"acceptedCalls\": 4,\n    \"missedCalls\": 1,\n    \"totalDurationSeconds\": 3600,\n    \"avgRingTimeMs\": 4200,\n    \"screenShareDurationSeconds\": 900\n  },\n  \"meetings\": {\n    \"totalMeetings\": 3,\n    \"totalParticipantMinutes\": 210,\n    \"avgParticipantsPerMeeting\": 4.3,\n    \"recordingsCreated\": 1\n  },\n  \"support\": {\n    \"ticketsOpened\": 2,\n    \"ticketsResolved\": 1,\n    \"avgFirstResponseSeconds\": 1200\n  }\n}"
            }
          ]
        },
        {
          "name": "Snapshot por rango de fechas",
          "request": {
            "method": "GET",
            "url": {
