	"item": [
		{
			"name": "Files",
			"item": [
				{
					"name": "InitiateUpload",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"status 201\", () => pm.response.code === 201 || pm.expect.fail(\"Got \" + pm.response.code + \": \" + pm.response.text()));",
									"const r = pm.response.json();",
									"pm.test(\"devuelve fileId y uploadUrl\", () => { pm.expect(r).to.have.property(\"fileId\"); pm.expect(r).to.have.property(\"uploadUrl\"); });",
									"if (r.fileId) {",
									"  pm.environment.set('fileId', r.fileId);",
									"  if (r.uploadUrl) pm.environment.set('uploadUrl', r.uploadUrl);",
									"  console.log('fileId guardado: ' + r.fileId + '. Sube el binario a uploadUrl y luego CompleteUpload.');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"originalName\": \"declaracion-2025.pdf\",\n  \"contentType\": \"application/pdf\",\n  \"sizeBytes\": 204800,\n  \"ownerType\": \"Customer\",\n  \"ownerId\": \"{{customerId}}\",\n  \"folderType\": \"Documents\",\n  \"taxYear\": 2025\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{UrlBase}}/storage/files/uploads",
							"host": [
								"{{UrlBase}}"
							],
							"path": [
								"storage",
								"files",
								"uploads"
							]
						},
						"description": "Inicia una subida. Devuelve fileId + uploadUrl presignada y FormData. Requiere permiso storage.file.upload. ownerType: Tenant|Customer|User|Signature|Invoice|Communication. folderType: Documents|Receipts|Invoices|EmailIncoming|EmailOutgoing|Tasks|Signatures|Avatars|Imports|Recordings|Backups|Other."
					},
					"response": []
				},
				{
					"name": "InitiateMultipartUpload",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"status 201\", () => pm.response.code === 201 || pm.expect.fail(\"Got \" + pm.response.code + \": \" + pm.response.text()));",
									"const r = pm.response.json();",
									"pm.test(\"devuelve fileId y uploadId\", () => { pm.expect(r).to.have.property(\"fileId\"); pm.expect(r).to.have.property(\"uploadId\"); });",
									"if (r.fileId) { pm.environment.set('fileId', r.fileId); }",
									"if (r.uploadId) { pm.environment.set('uploadId', r.uploadId); console.log('uploadId guardado. Sube cada parte a su uploadUrl y luego CompleteMultipartUpload con los ETags.'); }"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"originalName\": \"declaracion-2025.pdf\",\n  \"contentType\": \"application/pdf\",\n  \"sizeBytes\": 52428800,\n  \"ownerType\": \"Customer\",\n  \"ownerId\": \"{{customerId}}\",\n  \"folderType\": \"Documents\",\n  \"taxYear\": 2025\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{UrlBase}}/storage/files/uploads/initiate-multipart",
							"host": [
								"{{UrlBase}}"
							],
							"path": [
								"storage",
								"files",
								"uploads",
								"initiate-multipart"
							]
						},
						"description": "Fase U — arranca un upload multiparte: el browser sube cada parte directo a MinIO con las URLs devueltas (parts[].uploadUrl), sin pasar por CloudStorage. Requiere storage.file.upload."
					},
					"response": []
				},
				{
					"name": "CompleteMultipartUpload",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"uploadId\": \"{{uploadId}}\",\n  \"parts\": [\n    { \"partNumber\": 1, \"eTag\": \"\\\"etag-parte-1\\\"\" },\n    { \"partNumber\": 2, \"eTag\": \"\\\"etag-parte-2\\\"\" }\n  ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{UrlBase}}/storage/files/{{fileId}}/complete-multipart",
							"host": [
								"{{UrlBase}}"
							],
							"path": [
								"storage",
								"files",
								"{{fileId}}",
								"complete-multipart"
							]
						},
						"description": "Fase U — ensambla las partes ya subidas y sigue el mismo pipeline que CompleteUpload (verificar tamano, disparar escaneo). Requiere storage.file.upload."
					},
					"response": [],
