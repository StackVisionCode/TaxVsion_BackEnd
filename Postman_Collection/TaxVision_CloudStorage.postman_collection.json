		{
			"name": "Folders",
			"item": [
				{
					"name": "GetFolderContents",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{UrlBase}}/storage/folders?parentFolderId={{folderId}}&ownerType=Customer&ownerId={{customerId}}",
							"host": [
								"{{UrlBase}}"
							],
							"path": [
								"storage",
								"folders"
							],
							"query": [
								{
									"key": "parentFolderId",
									"value": "{{folderId}}",
									"description": "Omitir (o dejar vacio) para listar la raiz"
								},
								{
									"key": "ownerType",
									"value": "Customer",
									"description": "2026-07-20, opcional — solo staff interno. Filtra la respuesta a un solo dueno (ej. 'dame solo el arbol de este cliente') cuando la raiz de un tenant mezcla folders del propio tenant + de varios clientes. El portal de cliente (Scope.IsCustomerPortal) ignora este filtro, siempre ve solo lo suyo."
								},
								{
									"key": "ownerId",
									"value": "{{customerId}}",
									"description": "2026-07-20, opcional — va junto con ownerType. Omitir ambos para ver todos los duenos mezclados (comportamiento previo)."
								}
							]
						},
						"description": "Fase C2 — arbol navegable de UN NIVEL: subcarpetas + archivos directos de parentFolderId (null = raiz). Para navegación por clicks (tipo Explorer). Requiere storage.file.view.\n\nPara el arbol COMPLETO de una sola vez (sidebar expandible) usar GetFolderTree en su lugar."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"status 200\", () => pm.response.code === 200 || pm.expect.fail(\"Got \" + pm.response.code + \": \" + pm.response.text()));",
									"pm.test(\"incluye subfolders y files\", () => { const r = pm.response.json(); pm.expect(r).to.have.property(\"subfolders\"); pm.expect(r).to.have.property(\"files\"); });"
								]
							}
						}
					]
				},
