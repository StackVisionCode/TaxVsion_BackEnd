		{
			"name": "Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"const r = pm.response.json();",
							"if (r.mfaRequired) {",
							"  pm.environment.set('loginTicket', r.loginTicket);",
							"  console.log('MFA requerido. loginTicket guardado. Usa Auth/MFA/VerifyMfaChallenge.');",
							"} else if (r.tokens) {",
							"  pm.environment.set('accessToken', r.tokens.accessToken);",
							"  pm.environment.set('refreshToken', r.tokens.refreshToken);",
							"  if (r.tokens.deviceToken) pm.environment.set('deviceToken', r.tokens.deviceToken);",
							"  console.log('accessToken y refreshToken guardados' + (r.mfaSetupRequired ? ' (mfaSetupRequired=true)' : ''));",
							"}"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\r\n  \"tenantId\": \"{{tenantId}}\",\r\n  \"email\": \"jturbi@example.com\",\r\n  \"password\": \"Brittany040238.\"\r\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
