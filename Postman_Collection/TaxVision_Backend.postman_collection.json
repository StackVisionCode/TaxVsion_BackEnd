              "path": ["subscriptions", "current", "renew"],
              "query": [{ "key": "subscriptionId", "value": "{{subscriptionId}}" }]
            }
          },
          "response": []
        },
        {
          "name": "Change_Plan (TenantAdmin - aplica en renovacion)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.pendingChangeId) pm.environment.set(\"pendingChangeId\", response.pendingChangeId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"newPlanId\": \"{{planId}}\",\r\n  \"newBillingPeriod\": \"Annual\"\r\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{UrlBase}}/subscriptions/{{subscriptionId}}/change-plan",
              "host": ["{{UrlBase}}"],
              "path": ["subscriptions", "{{subscriptionId}}", "change-plan"]
            }
          },
          "response": []
        },
        {
          "name": "Apply_Pending_Change (PlatformAdmin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" }
            ],
            "url": {
              "raw": "{{UrlBase}}/subscriptions/pending-changes/{{pendingChangeId}}/apply",
              "host": ["{{UrlBase}}"],
              "path": ["subscriptions", "pending-changes", "{{pendingChangeId}}", "apply"]
            }
          },
          "response": []
        },
        {
          "name": "Update_Price (PlatformAdmin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"newPrice\": 35.00\r\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{UrlBase}}/subscriptions/{{subscriptionId}}/price",
              "host": ["{{UrlBase}}"],
              "path": ["subscriptions", "{{subscriptionId}}", "price"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Subscription / SubscriptionModules",
      "item": [
        {
          "name": "Get_SubscriptionModules",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" }
            ],
            "url": {
              "raw": "{{UrlBase}}/api/subscription-modules/subscription/{{subscriptionId}}?isIncluded=true",
              "host": ["{{UrlBase}}"],
              "path": ["api", "subscription-modules", "subscription", "{{subscriptionId}}"],
              "query": [{ "key": "isIncluded", "value": "true" }]
            }
          },
          "response": []
        },
        {
          "name": "Assign_Module_To_Subscription (PlatformAdmin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.id) pm.environment.set(\"subscriptionModuleId\", response.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"subscriptionId\": \"{{subscriptionId}}\",\r\n  \"moduleId\": \"{{moduleId}}\",\r\n  \"isIncluded\": true\r\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{UrlBase}}/api/subscription-modules",
              "host": ["{{UrlBase}}"],
              "path": ["api", "subscription-modules"]
            }
          },
          "response": []
        },
        {
          "name": "Remove_SubscriptionModule (PlatformAdmin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" }
            ],
            "url": {
              "raw": "{{UrlBase}}/api/subscription-modules/{{subscriptionModuleId}}",
              "host": ["{{UrlBase}}"],
              "path": ["api", "subscription-modules", "{{subscriptionModuleId}}"]
            }
          },
          "response": []
        }
      ]
    }
  ]
