							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const paymentId = pm.response.json();\r",
									"if (paymentId) {\r",
									"    pm.environment.set('tenantPaymentId', paymentId);\r",
									"    console.log('tenantPaymentId:', paymentId);\r",
									"}\r"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"providerCode\": \"Stripe\",\n  \"amountCents\": 1500,\n  \"currency\": \"USD\",\n  \"taxpayerId\": null,\n  \"purposeKind\": \"InvoicePayment\",\n  \"purposeExternalReferenceId\": \"inv-postman-001\",\n  \"paymentMethodReference\": \"pm_card_visa\",\n  \"receiptEmail\": null,\n  \"idempotencyKey\": \"postman-{{$guid}}\",\n  \"platformFeeAmountCents\": null,\n  \"platformFeeReference\": null\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{UrlBase}}/payments-client/payments",
